[Unit]
Description=Build the Satellite Capsule container image from Containerfile
Documentation=https://github.com/parmstro/quadlet-catalog/blob/main/definitions/capsule/README.md
After=network-online.target
Wants=network-online.target

[Build]
ImageTag=localhost/capsule:latest
File=Containerfile
SetWorkingDirectory=file

[Install]
WantedBy=multi-user.target
