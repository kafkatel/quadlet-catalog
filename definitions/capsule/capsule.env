# capsule.env
# Environment variables for Red Hat Satellite Capsule Server
# Copy this file and fill in your values before deploying.

# Capsule hostname (FQDN) -- REQUIRED
# Must resolve via DNS before starting capsule-installer
CAPSULE_HOSTNAME=capsule1.example.com

# Parent Satellite server -- REQUIRED
# The Capsule registers with this Satellite
SATELLITE_HOSTNAME=satellite1.example.com

# Organization and Location -- REQUIRED
# Must match the organization/location on the parent Satellite
CAPSULE_ORGANIZATION=Example_Org
CAPSULE_LOCATION=Default_Location

# Capsule registration credentials -- REQUIRED
# These are used to register the Capsule with the parent Satellite
# Typically a dedicated "Capsule" user or admin credentials
CAPSULE_REGISTER_USERNAME=admin
CAPSULE_REGISTER_PASSWORD=

# Capsule OAuth credentials -- GENERATED BY SATELLITE
# Generated during capsule-certs-generate on the Satellite
# Leave empty -- these will be provided via the certs tarball
CAPSULE_OAUTH_KEY=
CAPSULE_OAUTH_SECRET=

# Features to enable on the Capsule
# Set to 'true' to enable each feature
CAPSULE_FEATURE_CONTENT=true
CAPSULE_FEATURE_TFTP=true
CAPSULE_FEATURE_DHCP=false
CAPSULE_FEATURE_DNS=false
CAPSULE_FEATURE_ANSIBLE=true
CAPSULE_FEATURE_TEMPLATES=true

# Resource limits (lighter than full Satellite)
# Minimum: 8 GB RAM, 2 CPU cores, 50 GB disk
CONTAINER_CPUS=2
CONTAINER_MEMORY=8g
