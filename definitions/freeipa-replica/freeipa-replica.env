# freeipa-replica.env
# Environment variables for FreeIPA Replica
#
# Copy this file and fill in values before first deploy.
# After initial replica installation, these are not re-read -- all state
# lives in the persistent /data volume.

# IPA domain and realm
IPA_SERVER_HOSTNAME=idm-replica.los2.kafka.tel

# Primary server to replicate from
IPA_SERVER_INSTALL_OPTS=-U --setup-dns --forwarder=192.168.137.1 --server=bootstrap.los2.kafka.tel --domain=los2.kafka.tel --realm=LOS2.KAFKA.TEL --principal=admin --no-host-dns

# Admin password -- used only during initial replica install.
# Set this before first start, then remove or blank it after.
PASSWORD=
