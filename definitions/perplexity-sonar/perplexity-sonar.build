[Unit]
Description=Build the Perplexity Sonar container image from https://github.com/ppl-ai/modelcontextprotocol
After=network-online.target
Wants=network-online.target

[Build]
ImageTag=localhost/perplexity-sonar:latest
SetWorkingDirectory=https://github.com/ppl-ai/modelcontextprotocol.git#:perplexity-ask
