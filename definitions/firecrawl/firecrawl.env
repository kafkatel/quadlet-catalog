# firecrawl.env
# Environment variables file for Firecrawl services
# Copy this to /etc/firecrawl/ and customize with your values

# Redis Configuration
REDIS_URL=redis://firecrawl-redis:6379
REDIS_RATE_LIMIT_URL=redis://firecrawl-redis:6379

# Playwright Service
PLAYWRIGHT_MICROSERVICE_URL=http://firecrawl-playwright-service:3000/scrape

# Authentication & Database
USE_DB_AUTHENTICATION=

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Model Configuration
MODEL_NAME=
MODEL_EMBEDDING_NAME=

# Ollama Configuration
OLLAMA_BASE_URL=

# Slack Integration
SLACK_WEBHOOK_URL=

# Bull Queue Authentication
BULL_AUTH_KEY=

# Testing
TEST_API_KEY=

# Analytics - PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=

# Supabase Configuration
SUPABASE_ANON_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_TOKEN=

# Webhooks
SELF_HOSTED_WEBHOOK_URL=

# Search API Keys
SERPER_API_KEY=
SEARCHAPI_API_KEY=

# Logging
LOGGING_LEVEL=info

# Proxy Configuration
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# SearXNG Configuration
SEARXNG_ENDPOINT=
SEARXNG_ENGINES=
SEARXNG_CATEGORIES=

# Playwright Service Specific
BLOCK_MEDIA=

# Port Configuration (for overriding defaults)
PORT=3002
INTERNAL_PORT=3002