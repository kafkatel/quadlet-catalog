# quay.env
# Environment variables for the Quay container registry stack.
# Fill in empty values before deploying.

# Shared PostgreSQL password used by both quay-postgres and quay-clair-postgres.
# This same password must appear in:
#   - config.yaml       (DB_URI connection string)
#   - clair-config.yaml (connstring fields)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=
