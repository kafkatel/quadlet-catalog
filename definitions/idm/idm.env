# idm.env
# Environment variables for FreeIPA IdM Primary
# Copy this file and fill in your values before deploying.

# Server hostname (FQDN) -- REQUIRED
# Must resolve via DNS before starting the installer
IPA_SERVER_HOSTNAME=idm1.example.com

# Realm and domain -- REQUIRED
# Realm is typically the domain in UPPERCASE
IPA_REALM=EXAMPLE.COM
IPA_DOMAIN=example.com

# Admin password -- REQUIRED for first-run installation
# This is the password for the 'admin' user in IdM
# Minimum length: 8 characters
IPA_ADMIN_PASSWORD=

# Directory Manager password -- REQUIRED for first-run installation
# This is the LDAP directory superuser password
# Keep this secret -- it has full access to the LDAP database
IPA_DM_PASSWORD=

# DNS forwarders (optional)
# Leave empty to use root hints, or specify upstream DNS servers
# Format: comma-separated IPs
# Example: IPA_DNS_FORWARDERS=8.8.8.8,8.8.4.4
IPA_DNS_FORWARDERS=

# NTP servers (optional)
# Leave empty to use public NTP pool
# Format: comma-separated hostnames or IPs
# Example: IPA_NTP_SERVERS=0.pool.ntp.org,1.pool.ntp.org
IPA_NTP_SERVERS=

# Install options
# Set to 'yes' to run ipa-server-install non-interactively with the above values
# Set to 'no' (or leave empty) to run the installer interactively
IPA_UNATTENDED=no
