# immich.env
# Environment variables for the Immich photo management stack.
# Fill in empty values before deploying.

# Database password — alphanumeric only (A-Za-z0-9), no special characters.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=

# Database connection (used by the server; references the container name)
DB_HOSTNAME=immich-postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Redis connection (used by the server; references the container name)
REDIS_HOSTNAME=immich-redis

# Timezone
TZ=Etc/UTC
