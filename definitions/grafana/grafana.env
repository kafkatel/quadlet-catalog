# grafana.env
# Environment variables for Grafana.
# All settings follow the GF_<SECTION>_<KEY> pattern.
# See: https://grafana.com/docs/grafana/latest/setup-grafana/configure-grafana/

# Admin credentials — change before first start.
# Default is admin/admin which forces a password change on first login.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=

# Public URL (set when behind a reverse proxy)
#GF_SERVER_ROOT_URL=https://grafana.example.com

# Logging
GF_LOG_LEVEL=info

# Pre-install plugins at startup (comma-separated)
#GF_PLUGINS_PREINSTALL=grafana-clock-panel,grafana-piechart-panel
