# satellite.env
# Environment variables for Red Hat Satellite Server
# Copy this file and fill in your values before deploying.

# Server hostname (FQDN) -- REQUIRED
# Must resolve via DNS before starting satellite-installer
SATELLITE_HOSTNAME=satellite1.example.com

# Organization and Location -- REQUIRED
# Created during satellite-installer run
SATELLITE_ORGANIZATION=Example_Org
SATELLITE_LOCATION=Default_Location

# Admin credentials -- REQUIRED
# Initial admin user password for Satellite web UI
# Can be changed after first login
SATELLITE_ADMIN_USERNAME=admin
SATELLITE_ADMIN_PASSWORD=

# Red Hat CDN credentials -- REQUIRED for content sync
# Organization ID and activation key from Red Hat Customer Portal
# Or username/password for direct CDN access
RH_CDN_ORG_ID=
RH_CDN_ACTIVATION_KEY=
# Alternative: RH_CDN_USERNAME=
# Alternative: RH_CDN_PASSWORD=

# IdM Integration -- OPTIONAL
# Set to 'true' to integrate Satellite with IdM for Kerberos/DNS
# Requires an existing IdM deployment
SATELLITE_USE_IDM=false
IPA_SERVER=idm1.example.com
IPA_REALM=EXAMPLE.COM
IPA_DOMAIN=example.com

# Foreman Proxy (Smart Proxy) settings
# The primary Satellite runs a Smart Proxy locally
FOREMAN_PROXY_REGISTER=true
FOREMAN_PROXY_TFTP=true
FOREMAN_PROXY_TEMPLATES=true

# Database settings (PostgreSQL runs inside the container)
# Leave empty to use defaults
POSTGRES_DB=foreman
POSTGRES_USER=foreman
POSTGRES_PASSWORD=

# Resource limits
# Satellite requires substantial resources
# Minimum: 20 GB RAM, 4 CPU cores, 200 GB disk
CONTAINER_CPUS=4
CONTAINER_MEMORY=20g
