# forgejo-runner.env
# Environment variables for the Forgejo Actions runner
# Fill in before deploying.

# Forgejo instance URL -- REQUIRED
# The URL the runner uses to connect to Forgejo
FORGEJO_INSTANCE=https://git.example.com

# Runner registration token -- REQUIRED
# Get this from: Site Administration > Actions > Runners > Create new Runner
FORGEJO_TOKEN=

# Runner name (optional -- defaults to container hostname)
# RUNNER_NAME=runner-1

# Runner labels -- defines which workflow labels this runner handles
# Format: label:docker://image
RUNNER_LABELS=ubuntu-latest:docker://catthehacker/ubuntu:act-latest,docker:docker://docker:dind
