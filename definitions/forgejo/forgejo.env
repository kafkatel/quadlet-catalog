# forgejo.env
# Environment variables shared by Forgejo server and PostgreSQL
# Copy this file and fill in your values before deploying.

# PostgreSQL password -- REQUIRED
# Used by both the postgres container (POSTGRES_PASSWORD) and
# the Forgejo server (FORGEJO__database__PASSWD)
POSTGRES_PASSWORD=

# Forgejo database credentials
# These must match the PostgreSQL container configuration
FORGEJO__database__USER=forgejo
FORGEJO__database__PASSWD=${POSTGRES_PASSWORD}

# Server domain -- REQUIRED
# The public-facing hostname for the Forgejo instance
FORGEJO__server__DOMAIN=git.example.com
FORGEJO__server__ROOT_URL=https://git.example.com/
FORGEJO__server__SSH_DOMAIN=git.example.com
FORGEJO__server__SSH_PORT=2222

# Service settings
FORGEJO__service__DISABLE_REGISTRATION=false

# Quota -- unlimited (prevents quota system from blocking large uploads)
FORGEJO__quota_0X2E_default__TOTAL=-1
