# comfyui.env
# GPU and runtime environment for ComfyUI
# Copy this file and adjust for your GPU before deploying.

# --- AMD ROCm GPU Configuration ---

# GFX version override — REQUIRED for AMD GPUs
# This tells ROCm which ISA to target. Must match your GPU architecture.
# Common values:
#   gfx1100  = Radeon RX 7900 XTX / 7900 XT (RDNA 3)
#   gfx1101  = Radeon RX 7800 XT / 7700 XT (RDNA 3)
#   gfx1102  = Radeon RX 7600 (RDNA 3)
#   gfx1201  = Radeon AI PRO R9700 (RDNA 4)
#   gfx942   = Instinct MI300X (CDNA 3)
#   gfx90a   = Instinct MI250X (CDNA 2)
#   gfx908   = Instinct MI100 (CDNA 1)
#
# Find yours with: rocminfo | grep gfx
HSA_OVERRIDE_GFX_VERSION=11.0.0

# Limit to specific GPU (0-indexed). Leave empty to use all AMD GPUs.
# Useful when the system has an integrated GPU you want to skip.
HIP_VISIBLE_DEVICES=0

# ROCm memory and performance tuning
HSA_DISABLE_FRAGMENT_ALLOCATOR=1
PYTORCH_TUNABLEOP_ENABLED=1
FLASH_ATTENTION_TRITON_AMD_ENABLE=TRUE
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# --- NVIDIA GPU Configuration (uncomment if using NVIDIA) ---
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
